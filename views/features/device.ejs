<h4>Earphones</h4>
<div class="rating">★★★★☆</div>
<p class="price">₹2,299</p>
<button>Add to Cart</button>
</div>
</div>

</div>

</section>

<!-- ================= PROMO ================= -->
<section class="promo">
<div>
<h2>Flat 20% Off Work Essentials</h2>
<button>Explore Collection</button>
</div>
</section>

