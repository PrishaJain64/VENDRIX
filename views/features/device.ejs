<button>Add to Cart</button>
</div>
</div>

<div class="product-card" data-aos="fade-up" data-name="laptop sleeve">
<img src="https://cdn.cosmos.so/7c9e3010-118f-4efe-a69b-bb2cdde90e98?format=jpeg" alt="Laptop Sleeve">
