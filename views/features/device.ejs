<body>

<%- include('../partials/navbar.ejs') %>
<section class="image-slider">
<div class="slider-wrapper">

<div class="slide active">
<img src="https://cdn.cosmos.so/0892d087-b199-4e7c-a066-bdc38da3911d?format=jpeg" alt="Slide 1">
</div>

