<%
const icons ={};
icons["laptop"] = '💻';
icons["phone"] = '📱';
icons["smartwatch"]='⌚';
icons["camera"] = '📷';
icons["headphone"] = '🎧';
icons["earbuds"] =  'ᖰ  ᖳ';
icons["tablet"] = '🔲';
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Vendrix — Secure Payment</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@600;700;800;900&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/payment.css"/>
</head>
<body>

<div class="bg-grid"></div>
<div class="bg-orb bg-orb--a"></div>
<div class="bg-orb bg-orb--b"></div>

<!-- ── SUCCESS OVERLAY ── -->
<div class="success-overlay" id="js-success">
  <div class="success-modal">
    <div class="success-ring">
      <svg width="42" height="42" viewBox="0 0 42 42" fill="none">
        <circle cx="21" cy="21" r="19" stroke="#4ade80" stroke-width="1.5"/>
        <path d="M11 21l7 7 13-14" stroke="#4ade80" stroke-width="2.2"
          stroke-linecap="round" stroke-linejoin="round"
          stroke-dasharray="60" stroke-dashoffset="60"
          style="animation:checkmark .5s ease .45s both forwards"/>
      </svg>
    </div>
    <div class="success-title">Payment Successful</div>
    <div class="success-amount" id="suc-amount">₹1,80,399</div>
    <div class="success-txid" id="suc-txid">TXN-XXXXXX</div>
    <div class="success-sub">Your order has been confirmed. A receipt has been sent to your registered email.</div>
    <div class="success-details">
      <div class="suc-row"><span class="suc-row__lbl">Order ID</span><span class="suc-row__val">ORD-VX8K2F</span></div>
      <div class="suc-row"><span class="suc-row__lbl">Date &amp; Time</span><span class="suc-row__val" id="suc-date">—</span></div>
      <div class="suc-row"><span class="suc-row__lbl">Status</span><span class="suc-row__val" style="color:var(--green)">✓ Confirmed</span></div>
    </div>
    <button class="btn-done" onclick="closeSuc()"><i class="fas fa-arrow-left" style="margin-right:7px"></i>Back to Dashboard</button>
    <button class="btn-receipt" onclick="fakeDownload()"><i class="fas fa-download" style="margin-right:7px"></i>Download Receipt</button>
  </div>
</div>

<!-- ── HEADER ── -->
<header class="site-header">
  <div class="hdr-inner">
    <div class="hdr-brand">
      <a class="hdr-logo" href="#">VEND<span>R</span>IX</a>
      <span class="hdr-tag">Secure Checkout</span>
    </div>
  </div>
  <div class="prog-bar"><div class="prog-bar__fill" id="js-prog"></div></div>
</header>

<!-- ── PAGE ── -->
<div class="page">

  <!-- ══ LEFT ══ -->
  <div>

    <!-- ══ DELIVERY ADDRESS (always open, no dropdown) ══ -->
    <div class="addr-section-flat" id="addr-section">

      <div class="addr-section-title">
        <div class="addr-icon"><i class="fas fa-location-dot"></i></div>
        <div>
          <div class="addr-title">Delivery Address</div>
          <div class="addr-subtitle">Where should we send your order?</div>
        </div>
      </div>

      <div class="addr-content-flat">
        <div class="scan-line"></div>

        <!-- Saved addresses list -->
        <div class="section-label" style="margin-top:0"><i class="fas fa-bookmark"></i>Saved Addresses</div>
        <div class="saved-addr-list" id="saved-addr-list"></div>
        <div class="no-addr-msg" id="no-addr-msg">
          <i class="fas fa-map-pin" style="color:var(--og)"></i>
          <span>No saved addresses yet. Add one below.</span>
        </div>

        <!-- Add new address toggle -->
        <div class="add-addr-toggle" id="add-addr-toggle" onclick="toggleNewAddr()">
          <i class="fas fa-plus-circle"></i>
          <span id="add-addr-label">Add a new address</span>
        </div>
        <div class="addr-max-notice" id="addr-max-notice" style="display:none">
          <i class="fas fa-circle-info"></i> Maximum 3 addresses saved. Remove one to add a new address.
        </div>

        <!-- New address form -->
        <div class="new-addr-form" id="new-addr-form" style="display:none">

          <!-- Device Location -->
          <div class="device-loc-section">
            <button class="btn-device-loc" onclick="useDeviceLocation()">
              <i class="fas fa-location-crosshairs"></i> Use Device Location
            </button>
            <div class="device-loc-display" id="device-loc-display" style="display:none">
              <i class="fas fa-map-marker-alt" style="color:var(--og);font-size:11px;margin-top:2px;flex-shrink:0"></i>
              <span id="device-loc-txt">Fetching location…</span>
            </div>
          </div>

          <div class="section-label"><i class="fas fa-user"></i>Contact Details</div>
          <div class="grid-2 mb-field">
            <div>
              <div class="field-label"><i class="fas fa-user"></i>First Name</div>
              <input type="text" id="addr-fname" placeholder="Rahul" autocomplete="given-name"/>
              <div class="field-error" id="err-fname"></div>
            </div>
            <div>
              <div class="field-label"><i class="fas fa-user"></i>Last Name</div>
              <input type="text" id="addr-lname" placeholder="Sharma" autocomplete="family-name"/>
              <div class="field-error" id="err-lname"></div>
            </div>
          </div>
          <div class="mb-field">
            <div class="field-label"><i class="fas fa-phone"></i>Mobile Number</div>
            <div class="phone-flag-wrap">
              <select class="phone-code-sel" id="addr-code">
                <option value="+91">🇮🇳 +91</option>
                <option value="+1">🇺🇸 +1</option>
                <option value="+44">🇬🇧 +44</option>
                <option value="+971">🇦🇪 +971</option>
                <option value="+65">🇸🇬 +65</option>
                <option value="+61">🇦🇺 +61</option>
              </select>
              <input type="tel" id="addr-phone" placeholder="98765 43210" style="flex:1" autocomplete="tel-national"/>
            </div>
            <div class="field-error" id="err-phone"></div>
          </div>

          <div class="section-label"><i class="fas fa-map"></i>Address Details</div>
          <div class="grid-2 mb-field">
            <div>
              <div class="field-label"><i class="fas fa-door-open"></i>Flat / Wing</div>
              <input type="text" id="addr-flat" placeholder="e.g. 204, Wing B" autocomplete="off"/>
              <div class="field-error" id="err-flat"></div>
            </div>
            <div>
              <div class="field-label"><i class="fas fa-building"></i>Building Name</div>
              <input type="text" id="addr-building" placeholder="e.g. Crescent Heights" autocomplete="off"/>
              <div class="field-error" id="err-building"></div>
            </div>
          </div>
          <div class="mb-field">
            <div class="field-label"><i class="fas fa-map-pin"></i>Landmark</div>
            <input type="text" id="addr-landmark" placeholder="e.g. Near Andheri Station" autocomplete="off"/>
          </div>
          <div class="mb-field">
            <div class="field-label"><i class="fas fa-road"></i>Road Name</div>
            <input type="text" id="addr-road" placeholder="e.g. Link Road" autocomplete="off"/>
            <div class="field-error" id="err-road"></div>
          </div>
          <div class="grid-2 mb-field">
            <div>
              <div class="field-label"><i class="fas fa-city"></i>City</div>
              <input type="text" id="addr-city" placeholder="Mumbai" autocomplete="address-level2"/>
              <div class="field-error" id="err-city"></div>
            </div>
            <div>
              <div class="field-label"><i class="fas fa-map"></i>State</div>
              <input type="text" id="addr-state" placeholder="Maharashtra" autocomplete="address-level1"/>
              <div class="field-error" id="err-state"></div>
            </div>
          </div>
          <div class="grid-2 mb-field">
            <div>
              <div class="field-label"><i class="fas fa-globe"></i>Country</div>
              <input type="text" id="addr-country" placeholder="India" autocomplete="country-name"/>
              <div class="field-error" id="err-country"></div>
            </div>
            <div>
              <div class="field-label"><i class="fas fa-hashtag"></i>Pincode</div>
              <input type="text" id="addr-pin" maxlength="10" placeholder="e.g. 400053" oninput="onPinInput(this)" autocomplete="postal-code"/>
              <div class="field-error" id="err-pin"></div>
            </div>
          </div>

          <div class="section-label"><i class="fas fa-tag"></i>Address Type</div>
          <div class="addr-type-tabs" id="addr-type-tabs">
            <div class="addr-type-tab active" onclick="pickAddrType(this,'home')"><i class="fas fa-house"></i>Home</div>
            <div class="addr-type-tab" onclick="pickAddrType(this,'work')"><i class="fas fa-briefcase"></i>Work</div>
            <div class="addr-type-tab" onclick="pickAddrType(this,'other')"><i class="fas fa-location-dot"></i>Other</div>
          </div>

          <button class="btn-save-addr" onclick="saveNewAddr()">
            <i class="fas fa-circle-check"></i> Save &amp; Use This Address
          </button>
        </div>

      </div>
    </div><!-- /addr-section-flat -->

  </div>

  <!-- ══ RIGHT: SIDEBAR ══ -->
  <aside class="sidebar">
    <div class="summary-card" style="position:relative">
      <div class="summary-card__stripe"></div>
      <div class="summary-card__head">
        <div class="summary-card__title">Order Summary</div>
      </div>
      <div class="summary-card__body">
        <div class="summary-scan"></div>

        <%cartItems.forEach(element => {%>
        <div class="sum-item">
          <div class="sum-item__emo"><%=icons[element.device]|| "📦"%></div>
          <div class="sum-item__body">
            <div class="sum-item__name"><%=element.name%></div>
            <div class="sum-item__meta"><div class="sum-item__dot sum-item__dot--buy"></div><%=element.type%> · Qty <%=element.quantity%></div>
          </div>
          <div class="sum-item__price"><%=element.quantity*element.price%></div>
        </div>
        <%})%>
        <div class="sum-divider"></div>

        <div class="fee-row"><span><i class="fas fa-box"></i>Subtotal (<%=cartItems.length%> items)</span><span class="fee-row__val">₹<%=total%></span></div>
        <div class="fee-row"><span><i class="fas fa-truck"></i>Shipping</span><span class="fee-row__val" id="shipping-val"><span class="shipping-no-addr">Select an address first</span></span></div>
        <div class="fee-row"><span><i class="fas fa-percent"></i>GST (18%)</span><span class="fee-row__val" id="gst-val"><span class="shipping-no-addr">Select an address first</span></span></div>

        <div class="sum-divider sum-divider--og"></div>

        <div class="total-row">
          <div class="total-row__lbl">Total Due</div>
          <div class="total-row__amt" id="js-total">—</div>
        </div>
        <div class="total-note" id="total-note" style="opacity:0">*Inclusive of all taxes &amp; fees</div>

        <button class="btn-pay" id="js-pay" onclick="doPay(event)">
          <span class="btn-pay__sheen"></span>
          <i class="fas fa-bolt"></i> <span id="pay-btn-txt">Pay</span>
        </button>

        <div class="pay-note"><i class="fas fa-lock"></i>Secured by Vendrix Shield™</div>

      </div><!-- /summary-card__body -->

      <!-- Payment processing overlay on card -->
      <div class="pay-progress-overlay" id="pay-overlay">
        <div class="pay-progress-spinner"></div>
        <div class="pay-progress-label" id="pay-progress-lbl">Initializing…</div>
        <div class="pay-progress-bar-wrap">
          <div class="pay-progress-bar" id="pay-progress-bar"></div>
        </div>
      </div>
    </div>
  </aside>

</div><!-- /page -->

<div class="toast-wrap" id="toasts"></div>
<script src="/js/payment.js"></script>
</body>
</html>
