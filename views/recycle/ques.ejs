<% let k = 2;
   for(let q of questions){ %>
<div class="dq-slide" id="slide-<%= k %>">
  <div class="dq-question"><%= q.question %></div>
  <div class="dq-hint">Select one option below.</div>
  <div class="dq-options" data-name="<%= q.question %>" data-type="radio">
    <% for(let option of q.options){ %>
    <label class="dq-option">
      <input type="radio" name="issues[<%= q.question %>]" value="<%= option.text %>">
      <div class="dq-radio"><div class="dq-dot"></div></div>
      <span class="dq-opt-label"><%= option.text %></span>
    </label>
    <% } %>
  </div>
  <div class="dq-nav">
    <% if(k > 2){ %><button type="button" class="btn-prev" data-slideno="<%= k %>">Back</button><% } %>
    <button type="button" class="btn-next" data-slideno="<%= k %>">Continue</button>
  </div>
</div>
<% k++; } %>

<div class="dq-slide" id="slide-<%= k %>">
  <div class="dq-nav" style="margin-top:16px;">
    <button type="button" class="btn-prev" data-slideno="<%= k %>">Back</button>
    <button type="button" id="getvalue" class="btn-next" data-slideno="<%= k %>">Get Value</button>
  </div>
</div>
<div class="dq-slide" id="slide-<%= k +1%>">
  <div style = "display:none" id="deductions">
    <div class="price-card total-card">
        <div class="price-icon">🎉</div>
        <div class="price-label">You'll receive</div>
        <div class="price-amount total-amount" id="total-amount"></div>   
        <div class="price-sub">Great price for your device!</div>
        <div class="dq-nav" style="margin-top:16px;">
          <button type="button" id="payment" class="proceed">Proceed</button>
        </div>
      </div>
    </div>
  <div class="dq-nav" style="margin-top:16px;">
    <button type="button" id="pdfDownload" class=" pdf proceed btn-primary">
      Download Eco Report
    </button>
  </div>
</div>

</form>
<script src="/js/questionare.js"></script>
<script>
  var results = {};
  document.getElementById("getvalue").addEventListener("click",function(){
    const form = document.getElementById("form1");
    const formdata = new FormData(form);
    
      const device = "<%= spe.type %>";
      const actual_price = Number("<%= spe.base_recycle_value %>");
      results.device = device;
      results.baseprice = actual_price;
      results.name = '<%=spe.name%>';
      results.type=device;

      formdata.append("device",device);
      formdata.append("actual_price",actual_price);

    fetch("/answers/recycle",{
      method : "POST",
      body : formdata
    })
    .then(res=>res.json())
    .then(data =>{
      results.condition = data.condition;
      results.issues = data.issues;
      results.ecoimpact = data.eco_impact;
      results.csaved = data.csaved;
      results.ewsaved = data.ewsaved;
      results.ensaved = data.ensaved;
      results.finalprice = data.deductions;
      results.deductions = data.reduction;

      const deductions = data.deductions;
      document.getElementById('deductions').style.display="block";
      document.getElementById('total-amount').innerText = "₹"+deductions
    });
  });

  document.getElementById("pdfDownload").addEventListener("click",function(){
    fetch("/recycle/downloadpdf",{
      method:"post",
      headers: {
        "Content-Type": "application/json"
      },
      body : JSON.stringify(results)
    })
  });

</script>