<% layout('layouts/specifications-boilerplate') %>
<div id="cur-dot"></div>
<div id="cur-ring"></div>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-track">
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
  </div>
</div>

<!-- NAVBAR -->
<header class="v-navbar" id="navbar">
  <a href="#" class="logo">Vend<span class="accent">r</span>ix</a>
  <%- include('../partials/navbar.ejs') %>
  <div class="nav-right">
    <a href="/vendrix/aboutUs" class="nav-about">About Us</a>
    <%if(currentUser){%>
      <a href="/vendrix/profile"><span class="reviewer-avatar"><%=currentUser.firstname.slice(0,1)%></span></a>
    <%}else{%>
      <a href="/vendrix/register"><span class="nav-cta">Sign Up/In</span></a>
  <%}%>
    <a href="/vendrix/shoppingcart" class="nav-cta"><i class="fas fa-shopping-bag"></i> Cart</a>
    <a href="/recycle/<%=spe.type%>" class="nav-cta"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
</header>

<!-- BREADCRUMB -->
<div class="breadcrumb-bar">
  <a href="/vendrix">Home</a><span class="sep">›</span>
  <a href="/recycle/<%=spe.type%>">Recycle</a><span class="sep">›</span>
  <span class="cur"><%=spe.name%></span>
</div>

<main class="product-page">

  <!-- ══ LEFT: GALLERY PANEL ══ -->
   <div class="gallery-panel" id="galleryPanel">

  <!-- ══ BOOTSTRAP CAROUSEL ══ -->
  <div id="productCarousel" class="carousel slide" data-bs-ride="false">

    <!-- indicators -->
    <div class="carousel-indicators" id="bsIndicators">
      <button 
        type="button" 
        data-bs-target="#productCarousel" 
        data-bs-slide-to="0" 
        class="active"
        aria-current="true"
        aria-label="Slide 1">
      </button>

      <% for(let i in spe.colors[0].images){ 
           let val = Number(i); %>

        <button 
          type="button" 
          data-bs-target="#productCarousel" 
          data-bs-slide-to="<%= val + 1 %>" 
          aria-label="<%= 'Slide ' + (val + 2) %>">
        </button>

      <% } %>
    </div>

    <div class="carousel-inner" id="bsInner">

      <div class="carousel-item active">
        <img src="<%= spe.colors[0].thumbnail.url %>" class="d-block w-50 mx-auto">
      </div>

      <% for(let val of spe.colors[0].images){ %>
        <div class="carousel-item">
          <img src="<%= val.url %>" class="d-block w-50 mx-auto">
        </div>
      <% } %>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
      <div class="v-arrow"><i class="fas fa-chevron-left"></i></div>
      <span class="visually-hidden">Previous</span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
      <div class="v-arrow"><i class="fas fa-chevron-right"></i></div>
      <span class="visually-hidden">Next</span>
    </button>

  </div>

</div>

  <div class="info-panel" id="infoPanel">

    <div class="product-eyebrow reveal"><span class="eyebrow-line"></span><span class="eyebrow-tag"><%=spe.type%></span></div>
    <div class="product-brand-label reveal"><%=spe.brand%></div>
    <h1 class="product-title reveal"><%=spe.name%></h1>

    <div class = "q1">
    <div class="price-block reveal rd1">
      <div class="price-label">Starting Price</div>
      <span class="price-value">INR</span>
      <div style = "display:inline" class="price-value" id="priceDisplay"><%=spe.maxvalue%></div>
    </div>
    <form id="form1" enctype="multipart/form-data">
    <div class="dq-slide active action-row reveal rd3" id="slide-1" style="margin-top:-6px;">
      <a href="#dp-wrap" data-slideno="1" class="btn-next btn-buy"><i class="fas fa-bolt"></i> Recycle Now</a>
    </div>

    <div class="divider"></div>

    <div class="specs-section reveal">
      <div class="specs-header" id="specsHeader">
        <div class="specs-title">Full Specifications</div>
        <div class="specs-toggle"><i class="fas fa-minus" id="specsToggleIcon"></i></div>
      </div>
      <div id="specsBody">
        <%for(let [key,value] of Object.entries(spe.specifications)){%>
        <div class="spec-row"><div class="spec-key"><%=key%></div><div class="spec-val"><%=value%>t</div></div>
        <%}%>
      </div>
    </div>
    </div>

      <div class="dq-wrap" id="dp-wrap">
      <div class="dq-main">
        <div class="dq-step-label" id="stepLabel">Step 1</div>
        <div class="dq-progress"><div class="dq-progress-bar" id="progressBar" style="width:0%"></div></div>
        <%- include("ques.ejs") %>
      </div>
      <div class="dq-sidebar">
        <div class="dq-sidebar-title">Device evaluation</div>
        <div id="summaryContent"><p class="dq-empty">Your answers will appear here.</p></div>
      </div>
    </div>

  </div>

</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src = "/js/specification.js"></script>
<script>
  document.getElementById("payment").addEventListener("click",function(){
    
    const formdata = new FormData();
    formdata.append("intent","recycle");
    formdata.append("quoted","<%=spe.maxvalue%>");  
    formdata.append("finalprice",results.finalprice);
    fetch("/vendrix/payableTransaction",{
      method:"post",
      body:formdata
    }).then(res=>res.json()).then(data=>{
      if(data.valid){
        window.location.href = "/vendrix/payableTransaction/recycle/"+'<%=spe._id%>';
      }else if(data.valid ==="notloggedin"){
      window.location.href = data.redirect;
    }
      
    })

  })
</script>