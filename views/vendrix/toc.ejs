<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Terms &amp; Conditions — Vendrix</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;500;600;700;800&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
/* ═══ TOKENS ═══ */
:root {
  --black:    #000000;
  --black2:   #080808;
  --black3:   #0f0f0f;
  --black4:   #161616;
  --black5:   #1e1e1e;
  --black6:   #282828;
  --orange:   #ff6200;
  --orange2:  #ff7c00;
  --orange3:  #e55500;
  --og:       rgba(255,98,0,0.18);
  --og-dim:   rgba(255,98,0,0.07);
  --og-glow:  rgba(255,98,0,0.40);
  --white:    #ffffff;
  --white85:  rgba(255,255,255,0.85);
  --white55:  rgba(255,255,255,0.55);
  --white30:  rgba(255,255,255,0.30);
  --white12:  rgba(255,255,255,0.12);
  --white06:  rgba(255,255,255,0.06);
  --white03:  rgba(255,255,255,0.03);
  --border:   rgba(255,98,0,0.22);
  --border-w: rgba(255,255,255,0.08);
  --nav-h:    66px;
  --radius:   12px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Manrope', sans-serif;
  background: var(--black2);
  color: var(--white85);
  overflow-x: hidden;
  cursor: none;
}

/* ═══ CURSOR ═══ */
#cur-dot {
  width: 6px; height: 6px;
  background: var(--orange); border-radius: 50%;
  position: fixed; z-index: 9999; pointer-events: none;
  transform: translate(-50%, -50%);
}
#cur-ring {
  width: 32px; height: 32px;
  border: 1.5px solid var(--orange); border-radius: 50%;
  position: fixed; z-index: 9998; pointer-events: none;
  transform: translate(-50%, -50%);
  transition: width 0.25s, height 0.25s, opacity 0.25s;
  opacity: 0.5;
}
body:hover #cur-ring { opacity: 1; }

/* ═══ TOPBAR ═══ */
.topbar {
  background: var(--black);
  height: 32px; overflow: hidden;
  border-bottom: 1px solid var(--border-w);
}
.topbar-track {
  display: flex; gap: 48px; align-items: center;
  height: 100%; white-space: nowrap;
  animation: scroll-left 28s linear infinite;
}
.topbar-item {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--white55);
}
.topbar-item::before {
  content: '\2736'; margin-right: 20px;
  color: var(--orange); font-size: 8px;
}
@keyframes scroll-left {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ═══ NAVBAR ═══ */
.navbar {
  position: sticky; top: 0; z-index: 900;
  height: var(--nav-h);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px;
  background: rgba(8,8,8,0.92);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--border-w);
  gap: 20px;
}
.logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px; letter-spacing: 0.05em;
  color: var(--white); text-decoration: none;
  flex-shrink: 0;
}
.logo .accent { color: var(--orange); }
.nav-center {
  display: flex; align-items: center; list-style: none;
  gap: 0; height: 100%; flex: 1; justify-content: center;
}
.nav-center > li {
  position: relative; height: 100%;
  display: flex; align-items: center;
}
.nav-center > li > a {
  display: flex; align-items: center; gap: 5px;
  height: 100%; padding: 0 16px;
  font-size: 13px; font-weight: 600;
  letter-spacing: 0.03em; color: var(--white55);
  text-decoration: none; white-space: nowrap;
  transition: color 0.2s;
  border-bottom: 2px solid transparent;
}
.nav-center > li > a:hover,
.nav-center > li:hover > a { color: var(--white); border-bottom-color: var(--orange); }
.chev { font-size: 9px; transition: transform 0.25s; }
.nav-center > li:hover .chev { transform: rotate(180deg); }
.drop-menu {
  position: absolute; top: calc(var(--nav-h) - 1px); left: 0;
  background: var(--black3); border: 1px solid var(--border-w);
  border-radius: 12px; min-width: 200px; padding: 8px 0;
  opacity: 0; pointer-events: none; transform: translateY(10px);
  transition: opacity 0.22s, transform 0.22s;
  box-shadow: 0 16px 48px rgba(0,0,0,0.6); z-index: 800;
}
.nav-center > li:hover .drop-menu { opacity: 1; pointer-events: auto; transform: translateY(0); }
.drop-item > a {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 20px; font-size: 13px; color: var(--white55); text-decoration: none;
  transition: color 0.18s, background 0.18s;
}
.drop-item:hover > a { color: var(--orange); background: var(--og-dim); }
.chev-r { font-size: 9px; color: var(--white30); }
.sub-menu {
  position: absolute; top: 0; left: 100%;
  background: var(--black4); border: 1px solid var(--border-w);
  border-radius: 12px; min-width: 160px; padding: 8px 0;
  opacity: 0; pointer-events: none; transform: translateX(8px);
  transition: opacity 0.2s, transform 0.2s;
  box-shadow: 0 12px 36px rgba(0,0,0,0.5);
}
.drop-item:hover .sub-menu { opacity: 1; pointer-events: auto; transform: translateX(0); }
.sub-menu a {
  display: block; padding: 9px 18px; font-size: 13px; color: var(--white55); text-decoration: none;
  transition: color 0.18s, background 0.18s;
}
.sub-menu a:hover { color: var(--orange); background: var(--og-dim); }
.nav-right { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
.nav-icon { color: var(--white55); font-size: 16px; text-decoration: none; transition: color 0.2s; }
.nav-icon:hover { color: var(--orange); }
.nav-about {
  font-size: 13px; font-weight: 600; color: var(--orange); text-decoration: none;
  letter-spacing: 0.04em; border-bottom: 1px solid var(--border); padding-bottom: 2px;
}
.nav-cta {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--orange); color: var(--white);
  font-size: 13px; font-weight: 600;
  padding: 9px 18px; border-radius: 8px; text-decoration: none;
  transition: background 0.2s, transform 0.15s; white-space: nowrap;
}
.nav-cta:hover { background: var(--orange2); transform: translateY(-1px); }
.nav-badge {
  display: inline-flex; align-items: center; justify-content: center;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--white); color: var(--orange);
  font-size: 10px; font-weight: 800; line-height: 1;
}

/* ═══ PAGE HERO ═══ */
.page-hero {
  min-height: 52vh;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
  padding: 100px 80px 120px;
  background: var(--black2);
}
.hero-noise {
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  background-size: 180px; pointer-events: none; opacity: 0.5;
}
.hero-orb {
  position: absolute; border-radius: 50%; pointer-events: none;
  background: radial-gradient(circle, rgba(255,98,0,0.10) 0%, transparent 70%);
  width: 600px; height: 600px; top: -180px; right: -80px;
}
.hero-orb2 {
  position: absolute; border-radius: 50%; pointer-events: none;
  background: radial-gradient(circle, rgba(255,98,0,0.05) 0%, transparent 70%);
  width: 350px; height: 350px; bottom: -80px; left: 80px;
}
.page-hero-inner { position: relative; z-index: 2; max-width: 900px; }
.hero-eyebrow {
  display: flex; align-items: center; gap: 14px; margin-bottom: 28px;
}
.hero-eyebrow-line { display: block; width: 36px; height: 2px; background: var(--orange); }
.hero-eyebrow span:last-child {
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--orange);
}
.page-hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(44px, 7vw, 80px);
  font-weight: 800; line-height: 1.05; color: var(--white); margin-bottom: 24px;
}
.page-hero h1 .og  { color: var(--orange); }
.page-hero h1 .dim { color: var(--white30); }
.hero-meta {
  display: flex; gap: 32px; flex-wrap: wrap; margin-top: 36px;
}
.hero-meta-item {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: var(--white30); font-weight: 500;
}
.hero-meta-item i { color: var(--orange); font-size: 13px; }

/* ═══ LAYOUT: SIDEBAR + CONTENT ═══ */
.tc-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 0;
  min-height: 100vh;
  align-items: start;
}

/* Sticky sidebar */
.tc-sidebar {
  position: sticky; top: var(--nav-h);
  padding: 56px 40px 56px 80px;
  border-right: 1px solid var(--border-w);
  max-height: calc(100vh - var(--nav-h));
  overflow-y: auto;
}
.tc-sidebar::-webkit-scrollbar { width: 2px; }
.tc-sidebar::-webkit-scrollbar-thumb { background: var(--orange3); }

.sidebar-label {
  font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--white30); margin-bottom: 20px;
}
.toc-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
.toc-list a {
  display: block; padding: 9px 14px;
  font-size: 13px; color: var(--white30); text-decoration: none; font-weight: 500;
  border-left: 2px solid transparent; border-radius: 0 6px 6px 0;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.toc-list a:hover, .toc-list a.active {
  color: var(--orange); border-left-color: var(--orange); background: var(--og-dim);
}
.sidebar-footer {
  margin-top: 40px; padding: 20px; background: var(--black5);
  border: 1px solid var(--border-w); border-radius: 12px;
}
.sidebar-footer p { font-size: 12px; color: var(--white30); line-height: 1.7; margin-bottom: 12px; }
.sidebar-footer a {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; font-weight: 600; color: var(--orange); text-decoration: none;
}
.sidebar-footer a:hover { text-decoration: underline; }

/* Content area */
.tc-content {
  padding: 56px 80px 96px 64px;
}

/* ═══ SECTION ═══ */
.tc-section {
  padding-bottom: 72px;
  border-bottom: 1px solid var(--border-w);
  margin-bottom: 72px;
  scroll-margin-top: calc(var(--nav-h) + 24px);
}
.tc-section:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }

.sec-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--og); border: 1px solid var(--border);
  border-radius: 20px; padding: 5px 14px; margin-bottom: 20px;
}
.sec-badge-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 14px; color: var(--orange); letter-spacing: 0.06em;
}
.sec-badge-label {
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--white30);
}

.tc-section h2 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 800; color: var(--white);
  margin-bottom: 24px; line-height: 1.2;
}
.tc-section h2 .og { color: var(--orange); }

.tc-section h3 {
  font-family: 'Syne', sans-serif;
  font-size: 18px; font-weight: 700; color: var(--white85);
  margin: 32px 0 12px;
}

.tc-section p {
  font-size: 14px; line-height: 1.9; color: var(--white55);
  margin-bottom: 16px;
}
.tc-section p:last-child { margin-bottom: 0; }
.tc-section p strong { color: var(--white85); font-weight: 600; }
.tc-section p a { color: var(--orange); text-decoration: none; }
.tc-section p a:hover { text-decoration: underline; }

/* Callout box */
.callout {
  background: var(--og-dim); border: 1px solid var(--border);
  border-radius: 12px; padding: 20px 24px;
  display: flex; gap: 16px; align-items: flex-start; margin: 24px 0;
}
.callout-icon { color: var(--orange); font-size: 16px; margin-top: 2px; flex-shrink: 0; }
.callout p { margin: 0; font-size: 14px; }

/* Warning callout */
.callout-warn {
  background: rgba(255,98,0,0.05); border-color: rgba(255,98,0,0.30);
}

/* Bullet list */
.tc-list { list-style: none; padding: 0; margin: 16px 0; display: flex; flex-direction: column; gap: 10px; }
.tc-list li {
  display: flex; gap: 12px; align-items: flex-start;
  font-size: 14px; line-height: 1.75; color: var(--white55);
}
.tc-list li::before {
  content: ''; flex-shrink: 0;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--orange); margin-top: 8px;
}
.tc-list li strong { color: var(--white85); font-weight: 600; }

/* Policy table */
.policy-table { width: 100%; border-collapse: collapse; margin: 24px 0; }
.policy-table th {
  text-align: left; padding: 12px 16px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--white30); border-bottom: 1px solid var(--border-w);
  background: var(--black5);
}
.policy-table th:first-child { border-radius: 8px 0 0 0; }
.policy-table th:last-child  { border-radius: 0 8px 0 0; }
.policy-table td {
  padding: 14px 16px; font-size: 13px; color: var(--white55);
  border-bottom: 1px solid var(--border-w); line-height: 1.65;
}
.policy-table tr:last-child td { border-bottom: none; }
.policy-table tr:hover td { background: var(--white03); }
.policy-table td strong { color: var(--white85); font-weight: 600; }
.pill {
  display: inline-block; padding: 3px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.05em;
}
.pill-green  { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
.pill-orange { background: var(--og); color: var(--orange); border: 1px solid var(--border); }
.pill-red    { background: rgba(239,68,68,0.10); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }

/* ═══ SECTION COMMON ═══ */
.sec-alt  { background: var(--black3); }

/* ═══ CTA STRIP ═══ */
.cta-strip {
  background: var(--black2); padding: 96px 80px;
  position: relative; overflow: hidden;
}
.cta-strip-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at center, rgba(255,98,0,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.cta-strip-inner {
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;
}
.cta-strip h2 {
  font-family: 'Syne', sans-serif; font-size: clamp(28px, 4vw, 44px);
  font-weight: 800; color: var(--white); line-height: 1.2;
}
.cta-strip h2 .og { color: var(--orange); }
.cta-strip p { font-size: 15px; color: var(--white55); margin-top: 12px; max-width: 480px; line-height: 1.7; }
.cta-actions { display: flex; gap: 14px; flex-shrink: 0; flex-wrap: wrap; }
.btn-fill {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--orange); color: var(--white); font-size: 14px; font-weight: 600;
  padding: 14px 28px; border-radius: 10px; text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.btn-fill:hover { background: var(--orange2); transform: translateY(-2px); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid var(--border-w); color: var(--white55);
  font-size: 14px; font-weight: 500;
  padding: 14px 28px; border-radius: 10px; text-decoration: none;
  transition: border-color 0.2s, color 0.2s, transform 0.15s;
}
.btn-ghost:hover { border-color: var(--orange); color: var(--orange); transform: translateY(-2px); }

/* ═══ FOOTER ═══ */
footer { background: var(--black); border-top: 1px solid var(--border-w); }
.footer-top {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px; padding: 64px 80px;
}
.footer-logo {
  font-family: 'Bebas Neue', sans-serif; font-size: 32px;
  letter-spacing: 0.04em; color: var(--white); text-decoration: none;
  display: block; margin-bottom: 16px;
}
.footer-about { font-size: 13px; line-height: 1.8; color: var(--white30); margin-bottom: 24px; max-width: 280px; }
.footer-socials { display: flex; gap: 10px; }
.fsoc {
  width: 36px; height: 36px; border: 1px solid var(--border-w); border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; color: var(--white30); text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.fsoc:hover { border-color: var(--orange); color: var(--orange); }
.footer-col-title {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--white); margin-bottom: 20px;
}
.footer-link {
  display: block; font-size: 13px; color: var(--white30);
  text-decoration: none; margin-bottom: 10px; transition: color 0.2s;
}
.footer-link:hover { color: var(--orange); }
.footer-bottom {
  border-top: 1px solid var(--border-w); padding: 24px 80px;
  display: flex; align-items: center; justify-content: space-between;
  font-size: 12px; color: var(--white30);
}
.footer-bottom-right { display: flex; gap: 24px; }
.footer-bottom-right a { color: var(--white30); text-decoration: none; transition: color 0.2s; }
.footer-bottom-right a:hover { color: var(--white55); }

/* ═══ REVEAL ═══ */
.reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.6s ease, transform 0.6s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-d1 { transition-delay: 0.1s; }
.reveal-d2 { transition-delay: 0.2s; }

/* ═══ SCROLLBAR ═══ */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--black2); }
::-webkit-scrollbar-thumb { background: var(--orange3); border-radius: 2px; }
</style>
</head>
