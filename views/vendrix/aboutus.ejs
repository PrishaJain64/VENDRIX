  },
  {
    icon:  'fas fa-bolt',
    title: 'Innovation',
    desc:  'We are building the infrastructure for circular tech in India \u2014 from AI-powered device grading to instant trade-in kiosks. The way we consume tech needs to change, and we are building the tools to do it.'
  }
];

function setVal(idx, el) {
  document.querySelectorAll('.value-item').forEach(function(v) { v.classList.remove('active'); });
  el.classList.add('active');
  var v = vals[idx];
  document.getElementById('vdIcon').innerHTML  = '<i class="' + v.icon + '"></i>';
  document.getElementById('vdTitle').textContent = v.title;
  document.getElementById('vdDesc').textContent  = v.desc;
}
</script>
</body>
</html>