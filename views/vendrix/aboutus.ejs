<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>About Us — Vendrix</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Syne:wght@400;500;600;700;800&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
/* ═══ TOKENS ═══ */
:root {
  --black:    #000000;
  --black2:   #080808;
  --black3:   #0f0f0f;
  --black4:   #161616;
  --black5:   #1e1e1e;
  --black6:   #282828;
  --orange:   #ff6200;
  --orange2:  #ff7c00;
  --orange3:  #e55500;
  --og:       rgba(255,98,0,0.18);
  --og-dim:   rgba(255,98,0,0.07);
  --og-glow:  rgba(255,98,0,0.40);
  --white:    #ffffff;
  --white85:  rgba(255,255,255,0.85);
  --white55:  rgba(255,255,255,0.55);
  --white30:  rgba(255,255,255,0.30);
  --white12:  rgba(255,255,255,0.12);
  --white06:  rgba(255,255,255,0.06);
  --white03:  rgba(255,255,255,0.03);
  --border:   rgba(255,98,0,0.22);
  --border-w: rgba(255,255,255,0.08);
  --nav-h:    66px;
  --radius:   12px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Manrope', sans-serif;
  background: var(--black2);
  color: var(--white85);
  overflow-x: hidden;
  cursor: none;
}

/* ═══ CURSOR ═══ */
#cur-dot {
  width: 6px; height: 6px;
  background: var(--orange); border-radius: 50%;
  position: fixed; z-index: 9999; pointer-events: none;
  transform: translate(-50%, -50%);
}
#cur-ring {
  width: 32px; height: 32px;
  border: 1.5px solid var(--orange); border-radius: 50%;
  position: fixed; z-index: 9998; pointer-events: none;
  transform: translate(-50%, -50%);
  transition: width 0.25s, height 0.25s, opacity 0.25s;
  opacity: 0.5;
}
body:hover #cur-ring { opacity: 1; }

/* ═══ TOPBAR ═══ */
.topbar {
  background: var(--black);
  height: 32px; overflow: hidden;
  border-bottom: 1px solid var(--border-w);
}
.topbar-track {
  display: flex; gap: 48px; align-items: center;
  height: 100%; white-space: nowrap;
  animation: scroll-left 28s linear infinite;
}
.topbar-item {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--white55);
}
.topbar-item::before {
  content: '\2736'; margin-right: 20px;
  color: var(--orange); font-size: 8px;
}
@keyframes scroll-left {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ═══ NAVBAR ═══ */
.navbar {
  position: sticky; top: 0; z-index: 900;
  height: var(--nav-h);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px;
  background: rgba(8,8,8,0.88);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--border-w);
}
.logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px; letter-spacing: 0.05em;
  color: var(--white); text-decoration: none;
}
.logo .accent { color: var(--orange); }
.nav-right { display: flex; align-items: center; gap: 20px; }
.nav-icon {
  color: var(--white55); font-size: 16px;
  text-decoration: none; transition: color 0.2s;
}
.nav-icon:hover { color: var(--orange); }
/* FIX 1: Cart removed. About Us styled as active page indicator */
.nav-about {
  font-size: 13px; font-weight: 600;
  color: var(--orange); text-decoration: none;
  letter-spacing: 0.04em;
  border-bottom: 1px solid var(--border);
  padding-bottom: 2px;
}

/* ═══ HERO ═══ */
.about-hero {
  min-height: 92vh;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
  padding: 100px 80px 160px;
  background: var(--black2);
}
.hero-noise {
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  background-size: 180px; pointer-events: none; opacity: 0.5;
}
.hero-orb {
  position: absolute; border-radius: 50%; pointer-events: none;
  background: radial-gradient(circle, rgba(255,98,0,0.12) 0%, transparent 70%);
  width: 700px; height: 700px; top: -200px; right: -100px;
}
.hero-orb2 {
  position: absolute; border-radius: 50%; pointer-events: none;
  background: radial-gradient(circle, rgba(255,98,0,0.06) 0%, transparent 70%);
  width: 400px; height: 400px; bottom: -100px; left: 100px;
}
.about-hero-inner { position: relative; z-index: 2; max-width: 780px; }
.hero-eyebrow {
  display: flex; align-items: center; gap: 14px; margin-bottom: 28px;
}
.hero-eyebrow-line { display: block; width: 36px; height: 2px; background: var(--orange); }
.hero-eyebrow span:last-child {
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--orange);
}
.about-hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(52px, 8vw, 96px);
  font-weight: 800; line-height: 1.0; color: var(--white); margin-bottom: 32px;
}
.about-hero h1 .og  { color: var(--orange); }
.about-hero h1 .dim { color: var(--white30); }
.hero-lead {
  font-size: 18px; line-height: 1.75; color: var(--white55);
  max-width: 580px; margin-bottom: 48px;
}
.hero-lead strong { color: var(--white85); font-weight: 600; }
.hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

.btn-fill {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--orange); color: var(--white);
  font-size: 14px; font-weight: 600;
  padding: 14px 28px; border-radius: 10px; text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.btn-fill:hover { background: var(--orange2); transform: translateY(-2px); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: 10px;
  border: 1px solid var(--border-w); color: var(--white55);
  font-size: 14px; font-weight: 500;
  padding: 14px 28px; border-radius: 10px; text-decoration: none;
  transition: border-color 0.2s, color 0.2s, transform 0.15s;
}
.btn-ghost:hover { border-color: var(--orange); color: var(--orange); transform: translateY(-2px); }

.hero-stats-bar {
  position: absolute; bottom: 0; left: 0; right: 0;
  display: grid; grid-template-columns: repeat(4,1fr);
  border-top: 1px solid var(--border-w);
  background: rgba(8,8,8,0.7); backdrop-filter: blur(12px);
}
.hstat {
  padding: 28px 32px; border-right: 1px solid var(--border-w);
  transition: background 0.2s;
}
.hstat:last-child { border-right: none; }
.hstat:hover { background: var(--og-dim); }
.hstat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 40px; letter-spacing: 0.04em;
  color: var(--orange); line-height: 1; margin-bottom: 6px;
}
.hstat-label {
  font-size: 12px; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase; color: var(--white30);
}

/* ═══ SECTION COMMON ═══ */
.sec { padding: 96px 80px; }
.sec-alt  { background: var(--black3); }
.sec-dark { background: var(--black4); }

.sec-label {
  display: flex; align-items: center; gap: 12px;
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--orange); margin-bottom: 16px;
}
.sec-label-line {
  display: block; width: 28px; height: 1.5px;
  background: var(--orange);
}
.sec-heading {
  font-family: 'Syne', sans-serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 800; line-height: 1.1; color: var(--white); margin-bottom: 16px;
}
.sec-heading .og  { color: var(--orange); }
.sec-heading .dim { color: var(--white30); }
.sec-sub {
  font-size: 16px; line-height: 1.75; color: var(--white55); max-width: 560px;
}

/* ═══ STORY ═══ */
.story-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center; margin-top: 64px;
}
.story-img { position: relative; }
.story-img-inner {
  width: 100%; aspect-ratio: 4/3;
  border-radius: 16px; overflow: hidden; border: 1px solid var(--border-w);
}
.story-img-inner img {
  width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s;
}
.story-img-inner:hover img { transform: scale(1.04); }
.story-badge {
  position: absolute; bottom: -20px; left: -20px;
  background: var(--orange);
  padding: 20px 24px; border-radius: 12px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px; letter-spacing: 0.04em; color: var(--white); line-height: 1;
  box-shadow: 0 8px 32px rgba(255,98,0,0.35);
}
.story-badge span {
  display: block; font-family: 'Manrope', sans-serif;
  font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(255,255,255,0.7); margin-top: 4px;
}
.story-text h3 {
  font-family: 'Syne', sans-serif;
  font-size: 28px; font-weight: 700; color: var(--white);
  margin-bottom: 20px; line-height: 1.25;
}
.story-text p { font-size: 15px; line-height: 1.85; color: var(--white55); margin-bottom: 20px; }
.story-text p strong { color: var(--white85); font-weight: 600; }
.story-divider { width: 48px; height: 2px; background: var(--orange); margin: 28px 0; }

/* ═══ MISSION ═══ */
.mission-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 24px; margin-top: 56px;
}
.mission-card {
  background: var(--black5); border: 1px solid var(--border-w);
  border-radius: 16px; padding: 36px 32px;
  position: relative; overflow: hidden;
  transition: border-color 0.3s, transform 0.3s;
}
.mission-card::before {
  content: ''; position: absolute; inset: 0;
  background: var(--og-dim); opacity: 0; transition: opacity 0.3s;
}
.mission-card:hover { border-color: var(--border); transform: translateY(-4px); }
.mission-card:hover::before { opacity: 1; }
.mission-card-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 64px; letter-spacing: 0.04em;
  color: var(--white06); line-height: 1;
  position: absolute; top: 20px; right: 24px; transition: color 0.3s;
}
.mission-card:hover .mission-card-num { color: var(--og); }
.mission-icon {
  width: 48px; height: 48px; background: var(--og);
  border-radius: 12px; display: flex; align-items: center; justify-content: center;
  font-size: 20px; color: var(--orange); margin-bottom: 24px; border: 1px solid var(--border);
}
.mission-card h4 {
  font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700;
  color: var(--white); margin-bottom: 12px;
}
.mission-card p { font-size: 14px; line-height: 1.8; color: var(--white55); }

/* ═══ VALUES ═══ */
.values-wrap {
  display: grid; grid-template-columns: 380px 1fr;
  gap: 80px; align-items: start; margin-top: 64px;
}
/* FIX 3: padding-left added so the orange ::before side bar is visible */
.value-list { display: flex; flex-direction: column; gap: 0; padding-left: 28px; }
.value-item {
  padding: 28px 0; border-bottom: 1px solid var(--border-w);
  cursor: pointer; transition: padding-left 0.3s; position: relative;
}
.value-item::before {
  content: ''; position: absolute; left: -28px; top: 0; bottom: 0;
  width: 2px; background: var(--orange);
  transform: scaleY(0); transition: transform 0.3s; transform-origin: top;
}
.value-item.active { padding-left: 12px; }
.value-item.active::before { transform: scaleY(1); }
.value-num {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase; color: var(--orange); margin-bottom: 8px;
}
.value-name {
  font-family: 'Syne', sans-serif; font-size: 20px; font-weight: 700;
  color: var(--white55); transition: color 0.3s;
}
.value-item.active .value-name { color: var(--white); }
.value-display {
  background: var(--black5); border: 1px solid var(--border-w);
  border-radius: 20px; padding: 48px; min-height: 360px;
  display: flex; flex-direction: column; justify-content: center;
  position: relative; overflow: hidden;
}
.value-display::before {
  content: ''; position: absolute; top: -60px; right: -60px;
  width: 200px; height: 200px; border-radius: 50%;
  background: radial-gradient(circle, var(--og-glow) 0%, transparent 70%);
  pointer-events: none;
}
.vd-icon { font-size: 40px; color: var(--orange); margin-bottom: 28px; }
.vd-title { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; color: var(--white); margin-bottom: 16px; }
.vd-desc { font-size: 15px; line-height: 1.85; color: var(--white55); max-width: 400px; }

/* ═══ SERVICES ═══ */
.services-grid {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: 2px; margin-top: 56px;
  border: 1px solid var(--border-w); border-radius: 16px; overflow: hidden;
}
.svc-item {
  background: var(--black5); padding: 40px 32px;
  border-right: 1px solid var(--border-w);
  position: relative; overflow: hidden; transition: background 0.3s;
}
/* FIX 4: nth-child(3n) removes right border on every 3rd item, not just :last-child */
.svc-item:nth-child(3n) { border-right: none; }
.svc-item:hover { background: var(--black6); }
.svc-item::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0;
  height: 2px; background: var(--orange);
  transform: scaleX(0); transition: transform 0.35s; transform-origin: left;
}
.svc-item:hover::after { transform: scaleX(1); }
.svc-icon-wrap {
  width: 52px; height: 52px; background: var(--og-dim);
  border: 1px solid var(--border); border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; color: var(--orange); margin-bottom: 20px;
}
.svc-item h4 { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 10px; }
.svc-item p  { font-size: 13px; line-height: 1.8; color: var(--white55); }

/* ═══ TEAM ═══ */
.team-grid {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 24px; margin-top: 56px;
}
.team-card {
  background: var(--black5); border: 1px solid var(--border-w);
  border-radius: 16px; overflow: hidden;
  transition: border-color 0.3s, transform 0.3s;
}
.team-card:hover { border-color: var(--border); transform: translateY(-6px); }
.team-img { width: 100%; aspect-ratio: 3/2; overflow: hidden; background: var(--black6); }
.team-img-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif; font-size: 48px;
  color: var(--orange); background: var(--og-dim);
}
.team-body { padding: 20px; }
.team-name { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
.team-role { font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--orange); margin-bottom: 12px; }
.team-socials { display: flex; gap: 10px; }
.team-soc {
  width: 30px; height: 30px; border: 1px solid var(--border-w); border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: var(--white55); text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.team-soc:hover { border-color: var(--orange); color: var(--orange); }

/* ═══ TIMELINE ═══ */
.timeline { position: relative; margin-top: 64px; }
.timeline-line {
  position: absolute; left: 50%; top: 0; bottom: 0;
  width: 1px; background: var(--border-w); transform: translateX(-50%);
}
.tl-item {
  display: grid; grid-template-columns: 1fr 60px 1fr;
  align-items: start; margin-bottom: 56px;
}
.tl-left { text-align: right; padding-right: 32px; }
.tl-right { padding-left: 32px; }
.tl-dot {
  width: 14px; height: 14px; background: var(--orange); border-radius: 50%;
  margin: 6px auto; box-shadow: 0 0 0 4px var(--og);
}
.tl-year { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 0.06em; color: var(--orange); margin-bottom: 6px; }
.tl-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
.tl-desc { font-size: 13px; line-height: 1.75; color: var(--white55); }

/* ═══ CONTACT / COMPANY INFO ═══ */
.contact-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 60px; align-items: start; margin-top: 56px;
}
.contact-info-block { display: flex; flex-direction: column; gap: 20px; }
.contact-row {
  display: flex; align-items: flex-start; gap: 20px;
  background: var(--black5); border: 1px solid var(--border-w);
  border-radius: 14px; padding: 24px 28px;
  transition: border-color 0.3s, transform 0.2s;
}
.contact-row:hover { border-color: var(--border); transform: translateX(4px); }
.contact-row-icon {
  width: 44px; height: 44px; flex-shrink: 0;
  background: var(--og); border: 1px solid var(--border); border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; color: var(--orange);
}
.contact-row-label {
  font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--white30); margin-bottom: 6px;
}
.contact-row-value {
  font-size: 14px; font-weight: 500; color: var(--white85); line-height: 1.7;
}
.contact-row-value a { color: var(--orange); text-decoration: none; }
.contact-row-value a:hover { text-decoration: underline; }

.company-card {
  background: var(--black5); border: 1px solid var(--border-w);
  border-radius: 20px; padding: 40px;
  position: relative; overflow: hidden;
}
.company-card::before {
  content: ''; position: absolute; top: -80px; right: -80px;
  width: 220px; height: 220px; border-radius: 50%;
  background: radial-gradient(circle, var(--og-glow) 0%, transparent 70%);
  pointer-events: none;
}
.company-card-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px; letter-spacing: 0.05em; color: var(--white); margin-bottom: 8px;
}
.company-card-logo span { color: var(--orange); }
.company-card-tagline {
  font-size: 13px; color: var(--white30); margin-bottom: 28px;
  line-height: 1.6; max-width: 320px;
}
.company-divider { width: 40px; height: 1.5px; background: var(--orange); margin-bottom: 28px; }
.company-detail-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 13px 0; border-bottom: 1px solid var(--border-w);
}
.company-detail-row:last-child { border-bottom: none; padding-bottom: 0; }
.cdl { font-size: 12px; color: var(--white30); font-weight: 500; }
.cdv { font-size: 13px; color: var(--white85); font-weight: 600; text-align: right; }

/* ═══ CTA STRIP ═══ */
.cta-strip {
  background: var(--black2); padding: 96px 80px;
  position: relative; overflow: hidden;
}
.cta-strip-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at center, rgba(255,98,0,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.cta-strip-inner {
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap;
}
.cta-strip h2 {
  font-family: 'Syne', sans-serif; font-size: clamp(28px, 4vw, 44px);
  font-weight: 800; color: var(--white); line-height: 1.2;
}
.cta-strip h2 .og { color: var(--orange); }
.cta-strip p { font-size: 15px; color: var(--white55); margin-top: 12px; max-width: 480px; line-height: 1.7; }
.cta-actions { display: flex; gap: 14px; flex-shrink: 0; flex-wrap: wrap; }

/* ═══ FOOTER ═══ */
footer { background: var(--black); border-top: 1px solid var(--border-w); }
.footer-top {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px; padding: 64px 80px;
}
.footer-logo {
  font-family: 'Bebas Neue', sans-serif; font-size: 32px;
  letter-spacing: 0.04em; color: var(--white); text-decoration: none;
  display: block; margin-bottom: 16px;
}
.footer-about { font-size: 13px; line-height: 1.8; color: var(--white30); margin-bottom: 24px; max-width: 280px; }
.footer-socials { display: flex; gap: 10px; }
.fsoc {
  width: 36px; height: 36px; border: 1px solid var(--border-w); border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; color: var(--white30); text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.fsoc:hover { border-color: var(--orange); color: var(--orange); }
.footer-col-title {
  font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--white); margin-bottom: 20px;
}
.footer-link {
  display: block; font-size: 13px; color: var(--white30);
  text-decoration: none; margin-bottom: 10px; transition: color 0.2s;
}
