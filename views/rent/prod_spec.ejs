<% layout('layouts/questions') %>
<div class="card mb-3 d-flex flex-column flex-md-row w-100">
  <div class="row g-0">
    <div class="col-md-4">
      <div id="carouselExampleIndicators" class="carousel slide carousel-dark" data-bs-ride="carousel">
        <div class="carousel-indicators">
          <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to= "0" class="active" aria-current="true" aria-label= "Slide 1"></button>
          <% for(let i in result.selectedDoc.color.images){ let val = Number(i); %>
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to= "<%= val+1 %>" aria-label= "<%= 'Slide '+(val+2) %>"></button>
          <% } %>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
            <img src= "<%=result.selectedDoc.color.thumbnail.url %>" class="d-block w-100" >
            </div>
            <% for(let val of result.selectedDoc.color.images){ %>
              <div class="carousel-item">
                <img src= "<%=val["url"] %>" class="d-block w-100">
              </div>
            <%}%>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
        </div>
    </div>
    <div class="col-md-8">
      <div class="card-body">
        <p><%= result.selectedDoc.type %></p>
        <p id ="brand"><%=result.selectedDoc.brand%></p>
        <h5 class="card-title" id="name"><%= result.selectedDoc.name %></h5>
        <form>
          <label for="variants">Variants:</label>
                <%for(let [r,md] of result.variants.entries()){%>
                  <input type = "submit" formaction="/rent/details/<%= result.selectedDoc.name %>/<%= md.label %>/<%=result.selectedDoc.color.color%>" value = "<%=md.label%>" />
                <%}%>
                <br>
                <span>Variant : </span>
          </form>
        
        <p class="card-text">
            <span>Price: </span>
            <span id = "price"></span>
            
            <p>
              <label for="specs">Specification:</label>
                <%for(let [key,value] of Object.entries(result.selectedDoc.specifications)){ %>
                  <p><%=key%> : <%=value%></p>
                <%}%>
            </p>
            <form id = "form1">
              <p>
              <label>Colour: </label><br>
              <% for(let [i,md] of result.colors.entries()){ %>
                  <input type = "submit" formaction="/rent/details/<%= result.selectedDoc.name %>/<%= result.selectedDoc.variant.label %>/<%=md%>" value = "<%=md%>" />
              <% } %>
            </p>
            
        </p>
      </div>
    </div>
  </div>
</div>
  <p>Start Date : <input name = "startdate" type = "date" id = "startdate"></p>
  <p>End Date : <input name = "enddate" id = "enddate" type = "date"></p>
<button type = "button" id = "savedata">Rent</button>
</form>

<script src="/js/startdate.js"></script>
<script>
  const start = new Date();
  start.setDate(start.getDate()+3);
  start.setHours(0,0,0,0);
  const end = new Date(start);
  end.setDate(end.getDate()+7);
  end.setHours(0,0,0,0);

  const oneDay = 1000 * 60 * 60 * 24;
  const diffDays = Math.ceil((end - start) / oneDay);

  const price = document.getElementById("price");
  price.innerText = Math.round(diffDays*0.01*Number("<%= result.selectedDoc.variant.price.amount%>"));
  
  document.getElementById("savedata").addEventListener("click", function(){
    const form = document.getElementById("form1");
    const formdata = new FormData(form);

    const data = Object.fromEntries(formdata.entries());

    if(!data.startdate || !data.enddate){
      alert("Fill all the requirements");
    }else{
      const spe = "<%=result.selectedDoc.name %>";
      const label = "<%=result.selectedDoc.variant.label%>";
      const color = "<%=result.selectedDoc.color.color%>";
      formdata.append("product_name",spe);
      formdata.append("product_label",label);
      formdata.append("product_color",color);

      fetch("/rent/duration", {
      method: "POST",
      body: formdata
   }).then(res=>res.json())
   .then(data =>{
    window.location.href = data.redirect;
   });
  }
  });

  const startInput = document.getElementById("startdate");
  const endInput = document.getElementById("enddate");

  [startInput, endInput].forEach(input => {
    input.addEventListener("change", calculateRent);
  });

  function calculateRent(){

    if (!startInput.value || !endInput.value) return;

    const start = new Date(startInput.value);
    const end = new Date(endInput.value);

    start.setHours(0,0,0,0);
    end.setHours(0,0,0,0);

    const oneDay = 1000 * 60 * 60 * 24;
    const diffDays = Math.ceil((end - start) / oneDay);

    if (diffDays <= 0) {
      document.getElementById("price").innerText = "Invalid dates";
      return;
    }

    const amount = Number("<%= result.selectedDoc.variant.price.amount %>");
    const rent = Math.round(diffDays * 0.01 * amount);

    document.getElementById("price").innerText = rent;
  }
</script>
