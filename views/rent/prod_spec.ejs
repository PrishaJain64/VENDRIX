<% layout('layouts/specifications-boilerplate') %>
<div id="cur-dot"></div>
<div id="cur-ring"></div>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-track">
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
  </div>
</div>

<!-- NAVBAR -->
<header class="v-navbar" id="navbar">
  <a href="#" class="logo">Vend<span class="accent">r</span>ix</a>
  <%- include('../partials/navbar.ejs') %>
  <div class="nav-right">
    <a href="#" class="nav-about">About Us</a>
    <a href="#" class="nav-icon"><i class="fas fa-user"></i></a>
    <a href="#" class="nav-icon" style="position:relative"><i class="fas fa-shopping-bag"></i><span class="nav-badge">3</span></a>
    <a href="/rent/<%=result.selectedDoc[0].type%>" class="nav-cta"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
</header>

<!-- BREADCRUMB -->
<div class="breadcrumb-bar">
  <a href="/">Home</a><span class="sep">›</span>
  <a href="/rent/<%=result.selectedDoc[0].type%>">Rent</a><span class="sep">›</span>
  <span class="cur"><%=result.selectedDoc[0].name%></span>
</div>

<main class="product-page">

  <!-- ══ LEFT: GALLERY PANEL ══ -->
   <div class="gallery-panel" id="galleryPanel">

  <!-- ══ BOOTSTRAP CAROUSEL ══ -->
  <div id="productCarousel" class="carousel slide" data-bs-ride="false">

    <!-- indicators -->
    <div class="carousel-indicators" id="bsIndicators">
      <button 
        type="button" 
        data-bs-target="#productCarousel" 
        data-bs-slide-to="0" 
        class="active"
        aria-current="true"
        aria-label="Slide 1">
      </button>

      <% for(let i in result.selectedDoc[0].images){ 
           let val = Number(i); %>

        <button 
          type="button" 
          data-bs-target="#productCarousel" 
          data-bs-slide-to="<%= val + 1 %>" 
          aria-label="<%= 'Slide ' + (val + 2) %>">
        </button>

      <% } %>
    </div>

    <div class="carousel-inner" id="bsInner">

      <div class="carousel-item active">
        <img src="<%= result.selectedDoc[0].color.thumbnail.url %>" class="d-block w-50 mx-auto">
      </div>

      <% for(let val of result.selectedDoc[0].color.images){ %>
        <div class="carousel-item">
          <img src="<%= val.url %>" class="d-block w-50 mx-auto">
        </div>
      <% } %>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
      <div class="v-arrow"><i class="fas fa-chevron-left"></i></div>
      <span class="visually-hidden">Previous</span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
      <div class="v-arrow"><i class="fas fa-chevron-right"></i></div>
      <span class="visually-hidden">Next</span>
    </button>

  </div>

</div>

  <div class="info-panel" id="infoPanel">

    <div class="product-eyebrow reveal"><span class="eyebrow-line"></span><span class="eyebrow-tag"><%=result.selectedDoc[0].type%></span></div>
    <div class="product-brand-label reveal"><%=result.selectedDoc[0].brand%></div>
    <h1 class="product-title reveal"><%=result.selectedDoc[0].name%></h1>

    <div class="rating-row reveal rd1">
      <span class="stars-og">★★★★★</span>
      <span class="rating-num">4.8</span>
      <span class="rating-count">· 2,340 reviews</span>
      <div class="stock-pill"><span class="stock-dot"></span><span class="stock-text">In Stock</span></div>
    </div>

    <div class="price-block reveal rd1">
      <div class="price-label">Starting Price</div>
      <div class="price-value" id="price"></div>
    </div>
    <form>
    <div class="option-group reveal rd2">
      <div class="variant-grid">
        <%for(let [r,md] of result.labels[0].labels.entries()){%>
        <input type ="submit" formaction="/rent/details/<%= result.selectedDoc[0].name %>/<%= md %>/<%=result.selectedDoc[0].color.color%>" class="variant-btn <%= md == result.selectedDoc[0].variant.label ? 'selected' : '' %>" value = "<%=md%>" />
        <%}%>
      </div>
    </div>
    </form>
    <form>
    <div class="option-group reveal rd2" style="margin-bottom:32px;">
      <div class="option-label">Colour — <span class="chosen" id="selectedColor"><%=result.selectedDoc[0].color.color%></span></div>
      <div class="color-swatches">
        <%for(let md of result.colors[0].colors){%>
            <input type = "submit" class="color-swatch <%= md.color == result.selectedDoc[0].color.color ? 'selected' : '' %>" style ="background: <%=md.hexcode%>" formaction="/rent/details/<%= result.selectedDoc[0].name %>/<%= result.selectedDoc[0].variant.label %>/<%=md.color%>" value=""/>
        <%}%>
      </div>
    </div>
    </form>

    <form method = "post" id = "form1">
        <input type="hidden" name="quantity" class="hidden-qty" value="<%=result.quantity&&result.quantity>1?result.quantity-1:1%>">
        <input type="hidden" name="returnTo" value="<%=currentUrl%>">
        <div class="qty-row reveal rd3">
      <span class="qty-label">Qty</span>
      <div class="qty-ctrl">
        <button type="button" class="qty-btn minus" <%=Number(result.quantity)<=1?"disabled":""%>><i class="fas fa-minus" style="font-size:11px"></i></button>
        <div class="qty-val" id="qtyVal"><%=result.quantity?result.quantity:1%></div>
        <button type="button" data-id="<%= result.selectedDoc[0].available %>" class="qty-btn plus"><i class="fas fa-plus" style="font-size:11px"></i></button>
      </div>
    </div>
    <div class="action-row reveal rd3">
      <button formaction="/vendrix/cart/rent/<%=result.selectedDoc[0]._id%>/0/0" class="btn-primary">
        <i class="fas fa-shopping-bag"></i><span id="cartBtnText">Add to Cart</span>
      </button>
    </div>
    <div class="action-row reveal rd3" style="margin-top:-6px;">
      <p>Start Date : <input name = "startdate" type = "date" id = "startdate"></p>
      <p>End Date : <input name = "enddate" id = "enddate" type = "date"></p>
      <button class = "btn-buy" type = "button" id = "savedata">Rent Now</button>
    </div>
    </form>

    <div class="trust-strip reveal rd4">
      <div class="trust-it"><i class="fas fa-shipping-fast"></i><span>Free Delivery</span></div>
      <div class="trust-it"><i class="fas fa-shield-alt"></i><span>1 Year Warranty</span></div>
      <div class="trust-it"><i class="fas fa-undo"></i><span>10-Day Returns</span></div>
    </div>

    <div class="divider"></div>

    <div class="specs-section reveal">
      <div class="specs-header" id="specsHeader">
        <div class="specs-title">Full Specifications</div>
        <div class="specs-toggle"><i class="fas fa-minus" id="specsToggleIcon"></i></div>
      </div>
      <div id="specsBody">
        <%for(let [key,value] of Object.entries(result.selectedDoc[0].specifications)){%>
        <div class="spec-row"><div class="spec-key"><%=key%></div><div class="spec-val"><%=value%>t</div></div>
        <%}%>
      </div>
    </div>

  </div>

</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>  
<script src = "/js/specification.js"></script>
<script src="/js/counter.js"></script>
<script src="/js/startdate.js"></script>
<script>
  const start = new Date();
  start.setDate(start.getDate()+3);
  start.setHours(0,0,0,0);
  const end = new Date(start);
  end.setDate(end.getDate()+7);
  end.setHours(0,0,0,0);

  const oneDay = 1000 * 60 * 60 * 24;
  const diffDays = Math.ceil((end - start) / oneDay);

  const price = document.getElementById("price");
  var value = Math.round(diffDays*0.01*Number("<%= result.selectedDoc[0].variant.price.amount%>"));
  price.innerText =`₹${value} for ${diffDays} days`;
  
  document.getElementById("savedata").addEventListener("click", function(){
    const form = document.getElementById("form1");
    const formdata = new FormData(form);

    const data = Object.fromEntries(formdata.entries());

    if(!data.startdate || !data.enddate){
      alert("Fill all the requirements");
      return;
    }else{
      const spe = "<%=result.selectedDoc[0].name %>";
      const label = "<%=result.selectedDoc[0].variant.label%>";
      const color = "<%=result.selectedDoc[0].color.color%>";
      formdata.append("product_name",spe);
      formdata.append("product_label",label);
      formdata.append("product_color",color);

      fetch("/rent/duration", {
      method: "POST",
      body: formdata
   }).then(res=>res.json())
   .then(data =>{
    window.location.href = data.redirect;
   });
  }
  });

  const startInput = document.getElementById("startdate");
  const endInput = document.getElementById("enddate");

  [startInput, endInput].forEach(input => {
    input.addEventListener("change", calculateRent);
  });

  function calculateRent(){

    if (!startInput.value || !endInput.value) return;

    const start = new Date(startInput.value);
    const end = new Date(endInput.value);

    start.setHours(0,0,0,0);
    end.setHours(0,0,0,0);

    const oneDay = 1000 * 60 * 60 * 24;
    const diffDays = Math.ceil((end - start) / oneDay);

    if (diffDays <= 0) {
      document.getElementById("price").innerText = "Invalid dates";
      return;
    }

    const amount = Number("<%= result.selectedDoc[0].variant.price.amount %>");
    const rent = Math.round(diffDays * 0.01 * amount);

    price.innerText = `₹${rent} for ${diffDays} days`;
  }
</script>