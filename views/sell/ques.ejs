<div id="dp-wrap" class="dq-wrap">
  <div class="dq-main">
    <div class="dq-header">
      <div class="dq-step-label" id="stepLabel">Step 1 of <%= questions.length + 1 %></div>
      <div class="dq-progress"><div class="dq-progress-bar" id="progressBar" style="width:<%= (1/(questions.length+1)*100) %>%"></div></div>
    </div>

    <% let k = 2, j = 0, loc = -1;
       let total = questions.length + 1;
       for(let q of questions){
         if(q.question == "Additional Issues"){ loc = j; j++; continue; }
    %>
    <div class="dq-slide" id="slide-<%= k %>">
      <div class="dq-question"><%= q.question %></div>
      <div class="dq-hint">Select one option below.</div>
      <div class="dq-options" data-name="<%= q.question %>" data-type="radio">
        <% for(let option of q.options){ %>
        <label class="dq-option">
          <input type="radio" name="issues[<%= q.question %>]" value="<%= option.text %>">
          <div class="dq-radio"><div class="dq-dot"></div></div>
          <span class="dq-opt-label"><%= option.text %></span>
        </label>
        <% } %>
      </div>
      <div class="dq-nav">
        <% if(k > 2){ %><button type="button" class="btn-prev" data-slideno="<%= k %>">Back</button><% } %>
        <button type="button" class="btn-next" data-slideno="<%= k %>">Continue</button>
      </div>
    </div>
    <% k++; j++; } %>

    <!-- Additional Issues (checkbox) -->
    <% if(loc !== -1){ %>
    <div class="dq-slide" id="slide-<%= k %>">
      <div class="dq-question"><%= questions[loc].question %></div>
      <div class="dq-hint">Select all that apply.</div>
      <div class="dq-options" data-name="<%= questions[loc].question %>" data-type="checkbox">
        <% for(let option of questions[loc].options){ %>
        <label class="dq-option">
          <input type="checkbox" name="issues[<%= questions[loc].question %>]" value="<%= option.text %>">
          <div class="dq-check"><span class="dq-check-mark">✓</span></div>
          <span class="dq-opt-label"><%= option.text %></span>
        </label>
        <% } %>
      </div>
      <div class="dq-nav">
        <button type="button" class="btn-prev" data-slideno="<%= k %>">Back</button>
        <button type="button" id="getvalue" class="btn-next" data-slideno="<%= k %>">Continue</button>
      </div>
    </div>
    <% k++; } %>

    <!-- Upload + Proceed -->
    <div class="dq-slide" id="slide-<%= k %>">
      <div class="dq-question">Upload device photos</div>
      <div class="dq-hint">Help us assess condition accurately with clear photos.</div>
      <div class="dq-upload-area">
        <div class="dq-upload-box">
          <div class="dq-upload-label">Front View photo</div>
          <input type="file" accept="image/*" name="image" id="thumbnail">
        </div>
        <div class="dq-upload-box">
          <div class="dq-upload-label">Additional images</div>
          <input type="file" multiple accept="image/*" name="image" id="image">
        </div>
      </div>
      <div id="deductions"></div>
    <% if(intnt === "sell"){ %><div style="display: none;" id="total">
        <div class="price-card total-card">
        <div class="price-icon">🎉</div>
        <div class="price-label">You'll receive</div>
        <div class="price-amount total-amount" id="total-amount"></div>   
        <div class="price-sub">Great price for your device!</div>
      </div>
      </div><% } %>
      <div class="dq-nav">
        <button type="button" class="btn-prev" data-slideno="<%= k %>">Back</button>
        <button type="button" id="passdata" class = 'proceed'>Proceed</button>
      </div>
    </div>

  </div>

  <!-- Sidebar -->
  <div class="dq-sidebar">
    <div class="dq-sidebar-title">Device evaluation</div>
    <div id="summaryContent"><p class="dq-empty">Your answers will appear here.</p></div>
  </div>
</div>
</form>
<script>
  var deductions = null;
  var total = null;
  document.getElementById("getvalue").addEventListener("click",function(){
    const form = document.getElementById("form1");
    const formdata = new FormData(form);
      
      const device = "<%= spe.type %>";
      const actual_price = Number("<%= spe.variants[i].price %>");

      formdata.append("device",device);
      formdata.append("actual_price",actual_price);

    fetch("/answers/valuation",{
      method : "POST",
      body : formdata
    })
    .then(res=>res.json())
    .then(data =>{
      deductions = data.deductions;
      total = data.finalprice;

      if('<%=intnt%>' =="repair"){ 
        document.getElementById('deductions').innerHTML =`<div class="price-card total-card">
        <div class="price-icon">🎉</div>
        <div class="price-label">Total Pay </div>
        <div class="price-amount total-amount" id="total-amount">₹${deductions}</div>   
        <div class="price-sub">Great price for your device!</div>
      </div>`;

      }else{
      document.getElementById('deductions').innerHTML = `
      <div class="price-card deductions-card">
        <div class="price-icon">✦</div>
        <div class="price-label">Total Deductions</div>
        <div class="price-amount deduction-amount">− ₹${deductions}</div>
      </div>
    `;
  }

    document.getElementById('total').style.display="block";
    document.getElementById('total-amount').innerText = "₹"+total;

    });
  });
  </script>
<script src = "/js/questionare.js"></script>
