<% layout('layouts/specifications-boilerplate') %>
<div id="cur-dot"></div>
<div id="cur-ring"></div>

<!-- loading -->
<div class="lov" id="lov">
  <div class="lbox">
    <div class="lico">
      <svg class="lring" viewBox="0 0 50 50">
        <circle class="lring-bg" cx="25" cy="25" r="20"/>
        <circle class="lring-fill" cx="25" cy="25" r="20"/>
      </svg>
      <span class="lcount" id="lcount">10</span>
    </div>
    <div class="ltitle">Processing...</div>
    <p class="lsub" id="lsub">Please wait while we finalize your request.</p>
  </div>
</div> 

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-track">
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
  </div>
</div>

<!-- NAVBAR -->
<header class="v-navbar" id="navbar">
  <a href="#" class="logo">Vend<span class="accent">r</span>ix</a>
  <%- include('../partials/navbar.ejs') %>
  <div class="nav-right">
    <a href="/vendrix/aboutUs" class="nav-about">About Us</a>
    <%if(currentUser){%>
      <a href="/vendrix/profile"><span class="reviewer-avatar"><%=currentUser.firstname.slice(0,1)%></span></a>
    <%}else{%>
      <a href="/vendrix/register"><span class="nav-cta">Sign Up/In</span></a>
  <%}%>
        <a href="/vendrix/shoppingcart" class="nav-cta"><i class="fas fa-shopping-bag"></i> Cart</a>
    <a href="/allmodels/<%=intnt%>/<%=spe.type%>" class="nav-cta"><i class="fas fa-arrow-left"></i> Back</a>
  </div>
</header>

<!-- BREADCRUMB -->
<div class="breadcrumb-bar">
  <a href="/vendrix">Home</a><span class="sep">›</span>
  <a href="/allmodels/<%=intnt%>/<%=spe.type%>"><%=intnt%></a><span class="sep">›</span>
  <span class="cur"><%=spe.name%></span>
</div>

<main class="product-page">

  <!-- ══ LEFT: GALLERY PANEL ══ -->
   <div class="gallery-panel" id="galleryPanel">

  <!-- ══ BOOTSTRAP CAROUSEL ══ -->
  <div id="productCarousel" class="carousel slide" data-bs-ride="false">

    <!-- indicators -->
    <div class="carousel-indicators" id="bsIndicators">
      <button 
        type="button" 
        data-bs-target="#productCarousel" 
        data-bs-slide-to="0" 
        class="active"
        aria-current="true"
        aria-label="Slide 1">
      </button>

      <% for(let i in spe.colors[color_key].images){ 
           let val = Number(i); %>

        <button 
          type="button" 
          data-bs-target="#productCarousel" 
          data-bs-slide-to="<%= val + 1 %>" 
          aria-label="<%= 'Slide ' + (val + 2) %>">
        </button>

      <% } %>
    </div>

    <div class="carousel-inner" id="bsInner">

      <div class="carousel-item active">
        <img src="<%= spe.colors[color_key].thumbnail.url %>" class="d-block w-50 mx-auto">
      </div>

      <% for(let val of spe.colors[color_key].images){ %>
        <div class="carousel-item">
          <img src="<%= val.url %>" class="d-block w-50 mx-auto">
        </div>
      <% } %>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
      <div class="v-arrow"><i class="fas fa-chevron-left"></i></div>
      <span class="visually-hidden">Previous</span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
      <div class="v-arrow"><i class="fas fa-chevron-right"></i></div>
      <span class="visually-hidden">Next</span>
    </button>

  </div>

</div>

  <div class="info-panel" id="infoPanel">

    <div class="product-eyebrow reveal"><span class="eyebrow-line"></span><span class="eyebrow-tag"><%=spe.type%></span></div>
    <div class="product-brand-label reveal"><%=spe.brand%></div>
    <h1 class="product-title reveal"><%=spe.name%></h1>

    <div class="rating-row reveal rd1">
      <span class="stars-og">★★★★★</span>
      <span class="rating-num">4.8</span>
      <span class="rating-count">· 2,340 reviews</span>
      <div class="stock-pill"><span class="stock-dot"></span><span class="stock-text">In Stock</span></div>
    </div>

    <div class = "q1">
    <div class="price-block reveal rd1">
      <div class="price-label">Starting Price</div>
      <span class="price-value">INR</span>
      <div style = "display:inline" class="price-value" id="priceDisplay"><%=spe.variants[i].price%></div>
    </div>
    <form>
    <div class="option-group reveal rd2">
      <div class="variant-grid">
        <%for(let [r,md] of spe.variants.entries()){%>
        <input type ="submit" formaction="/allmodels/details/<%= spe._id %>/<%= r %>/<%=intnt%>/<%=color_key%>" class="variant-btn <%= r == i ? 'selected' : '' %>" value = "<%=md.label%>" />
        <%}%>
      </div>
    </div>
    </form>
    <form>
    <div class="option-group reveal rd2" style="margin-bottom:32px;">
      <div class="option-label">Colour — <span class="chosen" id="selectedColor"><%=spe.colors[color_key].color%></span></div>
      <div class="color-swatches">
        <%for(let [k,md] of spe.colors.entries()){ console.log(md.hexcode)%>
            <input type = "submit" class="color-swatch <%= k == color_key ? 'selected' : '' %>" style ="background: <%=md.hexcode%>" formaction="/allmodels/details/<%= spe._id %>/<%= i %>/<%=intnt%>/<%=k%>" value=""/>
        <%}%>
      </div>
    </div>
    </form>

    <form id = "form1" enctype="multipart/form-data">
    <div class="dq-slide active action-row reveal rd3" id="slide-1" style="margin-top:-6px;">
      <a href="#dp-wrap" class = "btn-next btn-buy" data-slideno="1"><i class="fas fa-bolt"></i> <%=intnt=="sell"?"Sell Now":"Repair Now"%></a>
    </div>

    <div class="trust-strip reveal rd4">
      <div class="trust-it"><i class="fas fa-shipping-fast"></i><span>Free Delivery</span></div>
      <div class="trust-it"><i class="fas fa-shield-alt"></i><span>1 Year Warranty</span></div>
      <div class="trust-it"><i class="fas fa-undo"></i><span>10-Day Returns</span></div>
    </div>

    <div class="divider"></div>

    <div class="specs-section reveal">
      <div class="specs-header" id="specsHeader">
        <div class="specs-title">Full Specifications</div>
        <div class="specs-toggle"><i class="fas fa-minus" id="specsToggleIcon"></i></div>
      </div>
      <div id="specsBody">
        <%for(let [key,value] of Object.entries(spe.specifications)){%>
        <div class="spec-row"><div class="spec-key"><%=key%></div><div class="spec-val"><%=value%>t</div></div>
        <%}%>
      </div>
    </div>
    </div>
    <%-include("ques.ejs")%>
  </div>

</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script src = "/js/specification.js"></script>
<script>

  document.getElementById("passdata").addEventListener("click", function(){
    if('<%=intnt%>' === "sell"){
    const img = document.getElementById("thumbnail");
    if(img.files.length==0){
      img.style.border = "2px solid red";
      alert("Uploading a front view photo is mandatory");
      return;
    }

    const form = document.getElementById("form1");
    const formdata = new FormData(form);

      const spe = "<%=spe._id %>";
      const intent = "<%= intnt%>";
      const i = Number('<%= i %>');
      const device = "<%= spe.type %>";
      const color = "<%= spe.colors[color_key].color%>";
      const hexcode = "<%= spe.colors[color_key].hexcode%>";
      const quoted = "<%=spe.variants[i].price%>"
      const finalprice = (Number(quoted) - Number(deductions)).toFixed(2);

      formdata.append("product_id",spe);
      formdata.append("ctr",i);
      formdata.append("device",device);
      formdata.append("intent",intent);
      formdata.append("deductions",deductions);
      formdata.append("hexcode",hexcode);
      formdata.append("color",color);

      showLoading("Please wait while we finalize your request.");
      fetch("/answers", {
      method: "POST",
      body: formdata
   }).then(res=>res.json())
   .then(data =>{
    
    // window.location.href = data.redirect;
    // onFetchComplete(data.redirect);
    if(data.valid){
      const formcontent = new FormData();
      formcontent.append("intent","sell");
      formcontent.append("quoted",quoted);  
      formcontent.append("finalprice",finalprice);
      fetch("/vendrix/payableTransaction",{
        method:"post",
        body:formcontent
      }).then(res=>res.json()).then(data=>{
        if(data.valid){
          window.location.href = "/vendrix/payableTransaction/sell/"+'<%=spe._id%>';
          onFetchComplete("/vendrix/payableTransaction/sell/"+'<%=spe._id%>')
        }
      
    })
    }

   });
   
  }else{
    const formdata = new FormData();
    formdata.append("intent","repair");
    formdata.append("total",deductions);    
    fetch("/vendrix/directTransaction",{
      method:"post",
      body:formdata
    }).then(res=>res.json()).then(data=>{
      if(data.valid)
      window.location.href = "/vendrix/directTransaction/repair/" + "<%= spe._id %>" + "/" + "<%= i %>" + "/" + "<%= color_key %>" + "/1"
    })

  }});
</script>