<% const categories = {"phone":"mobile",'laptop':'laptop','smartwatch':'clock','camera':'camera','headphone':'headphones','earbud':'headphones','tablet':'tablet'}
const products = [
  { category: "phone", brands: ["Apple", "Samsung", "OnePlus"] }, //
  { category: "laptop", brands: ["HP", "Lenovo", "Apple"] }, //
  { category: "smartwatch", brands: ["Apple", "Samsung"] }, 
  { category: "camera", brands: ["Canon", "Nikon"] }, //samsung
  { category: "headphone", brands: ["Sony", "JBL"] },
  { category: "earbud", brands: ["Boat", "Apple", "Samsung"] }, //boat 
  { category: "tablet", brands: ["Apple", "Samsung", "Lenovo"] } 
]%>
<% layout('layouts/features-boilerplate') %>
<!-- CURSOR -->
<div id="cur-dot"></div>
<div id="cur-ring"></div>

<!-- TOP BAR -->
<div class="topbar">
  <div class="topbar-track">
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
    <span class="topbar-item">Free Shipping Over ₹2,000</span>
    <span class="topbar-item">1 Year Warranty Included</span>
    <span class="topbar-item">Certified Refurbished Devices</span>
    <span class="topbar-item">Easy EMI Essentials</span>
    <span class="topbar-item">Expert Repair Services</span>
    <span class="topbar-item">All Devices Available</span>
  </div>
</div>

<!-- NAVBAR -->
<header class="navbar" id="navbar">
  <a href="vendrix.html" class="logo">Vend<span class="accent">r</span>ix</a>

  <%- include('../partials/navbar.ejs') %>
  <div class="nav-right">
    <a href="#" class="nav-about">About Us</a>
    <%if(currentUser){%>
      <a href="/vendrix/profile"><span class="reviewer-avatar"><%=currentUser.firstname.slice(0,1)%></span></a>
    <%}else{%>
      <a href="/vendrix/register"><span class="nav-cta">Sign Up/In</span></a>
  <%}%>
        <a href="/vendrix/shoppingcart" class="nav-cta"><i class="fas fa-shopping-bag"></i> Cart</a>

    <a href="/vendrix" class="nav-cta">
      <i class="fas fa-home"></i> Home
    </a>
  </div>
</header>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="/vendrix">Home</a>
  <span class="sep">›</span>
  <span class="cur"><%=intent == "sell"?'Sell' : 'Repair'%></span>
</div>

<!-- PAGE HERO -->
<div class="buy-hero">
  <div class="buy-hero-inner">
    <div class="buy-hero-eyebrow">
      <span class="buy-hero-line"></span>
      <span>Vendrix Store</span>
    </div>
    <h1>All <span class="og">Products</span></h1>
    <p class="buy-hero-sub">Certified devices. Premium quality. Shipped in 72 hours.</p>
  </div>
</div>

<!-- CATEGORY PILLS -->
<div class="cat-strip-wrap">
  <div class="cat-strip" id="categoryStrip">
    <%for(let [key,value] of Object.entries(categories)){%>
      <a href = "/allmodels/<%=intent%>/<%=key%>">
    <div class="cat-pill <% if(device===key){%><%="active"%><%}%>">
      <i class="fas fa-<%=value%> cat-pill-icon"></i><span><%=key[0].toUpperCase()+key.slice(1)%></span>
    </div></a>
    <%}%>
  </div>
</div>

<!-- SHOP LAYOUT -->
<div class="shop-layout">

  <!-- SIDEBAR OVERLAY (mobile) -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- FILTER SIDEBAR -->
  <aside class="filter-sidebar" id="filterSidebar">
    <div class="sidebar-head">
      <div class="sidebar-title">Filters</div>
      <a href = "/allmodels/<%=intent%>/<%=device%>" class="clear-all-btn" id="clearAll">Clear all</a>
    </div>

    <form method="post" action="/allmodels/filters/<%=intent%>/<%=device%>">
    <!-- Sort -->
    <div class="filter-section">
      <div class="filter-section-title open" data-target="sort-opts">
        Sort By <i class="fas fa-chevron-down"></i>
      </div>
      <div class="filter-opts visible" id="sort-opts">
        <label class="filter-label"><input type="radio" name="psort" value="0" <% if(psort && psort === 0){%><%="checked"%><%}%>> Default</label>
        <label class="filter-label"><input type="radio" name="psort" value="1" <% if(psort && psort === 1){%><%="checked"%><%}%>> Price: Low to High</label>
        <label class="filter-label"><input type="radio" name="psort" value="-1" <% if(psort && psort === -1){%><%="checked"%><%}%>> Price: High to Low</label>
        <label class="filter-label"><input type="radio" name="nsort" value="1" <% if(nsort && nsort === 1){%><%="checked"%><%}%>> Name: A to Z</label>
      </div>
    </div>

    <!-- Price -->
    <div class="filter-section">
      <div class="filter-section-title open" data-target="price-opts">
        Price Range <i class="fas fa-chevron-down"></i>
      </div>
      <div class="filter-opts visible" id="price-opts">
        <div class="price-display">
          <span>₹0</span>
          <span id="priceVal">₹<%if(pr){%><%=pr%><%}else{%><%=125000%><%}%></span>
        </div>
        <input name = "price" value = "<%if(pr){%><%=pr%><%}%>" type="range" class="price-slider" id="priceSlider" min="0" max="250000" step="1000">
      </div>
    </div>

    <!-- Brand -->
    <div class="filter-section">
      <div class="filter-section-title open" data-target="brand-opts">
        Brand <i class="fas fa-chevron-down"></i>
      </div>
      <div class="filter-opts visible" id="brand-opts">
      <label class="filter-label">
        <input id="all" name="brand" type="checkbox" class="brand-filter" value="all"
          <% if (br && br.includes("all")) { %> checked <% } %>>
        All
      </label>

      <% const cat = products.find(item => item.category === device); %>

      <% if (cat) { 
          for (let brand of cat.brands) { %>

        <label class="filter-label">
          <input id="<%= brand %>" name="brand" type="checkbox" class="brand-filter"
            value="<%= brand %>"
            <% if (br && br.includes(brand)) { %> checked <% } %>>
          <%= brand %>
        </label>

      <% } } %>
    </div>
    </div>

    <!-- Rating -->
    <!-- <div class="filter-section">
      <div class="filter-section-title open" data-target="rating-opts">
        Min Rating <i class="fas fa-chevron-down"></i>
      </div>
      <div class="filter-opts visible" id="rating-opts">
        <label class="filter-label"><input type="radio" name="rating" value="0" checked> All Ratings</label>
        <label class="filter-label"><input type="radio" name="rating" value="4"> 4★ & above</label>
        <label class="filter-label"><input type="radio" name="rating" value="4.5"> 4.5★ & above</label>
      </div>
    </div> -->

    <button class="apply-btn" id="applyFilters">
      <i class="fas fa-check" style="margin-right:8px"></i>Apply Filters
    </button>
    </form>
  </aside>

  <!-- GRID AREA -->
  <div class="grid-area">
    <div class="grid-topbar">
      <span class="results-count" id="resultsCount">Showing <strong><%=allmod.length%></strong> products</span>
      <div class="topbar-right">
        <button class="mobile-filter-btn" id="mobileFilterBtn">
          <i class="fas fa-sliders-h"></i> Filters
        </button>
        <!-- SEARCH BAR -->
        <div class="search-wrap">
          <form action="/allmodels/<%=intent%>/<%=device%>" method = "get">
          <input
          name = "search"
            type="text"
            id="productSearch"
            class="search-input"
            placeholder="Search products, brands…"
            autocomplete="off"
            spellcheck="false"
          />
          </form>
          <button class="search-clear" id="searchClear" aria-label="Clear search">
            <i class="fas fa-times"></i>
          </button>
          <i class="fas fa-search search-icon"></i>
        </div>
      </div>
    </div>

    <div class="active-chips" id="activeChips"></div>

    <div class="buy-grid" id="buyGrid">
      <%for(let p of allmod){%>
        <div class = 'buy-card'>
      <div class="buy-card-img">
        <img src="<%=p.colors[0].thumbnail.url%>" loading="lazy">
      </div>
      <div class="buy-card-info">
        <p class="buy-brand"><%=p.brand%></p>
        <h3 class="buy-name"><%=p.name%></h3>
        <div class="buy-price-row">
          <span class="buy-price">INR <%=p.variants[0].price%></span>
        </div>
        <a href="/allmodels/details/<%=p._id%>/0/<%=intent%>/0%>" class="buy-card-cta"><i class="fas fa-eye"></i> View Details</a>
      </div>
        </div>
        <%}%>
    </div>

    <div class="no-products" id="noProducts" style="display:none;">
      <i class="fas fa-box-open"></i>
      <p>No products match your filters.</p>
      <button class="reset-btn" id="resetBtn">Reset Filters</button>
    </div>
  </div>
</div>

<!-- FOOTER -->
  <%- include('../partials/footer.ejs') %>

<script src="/js/features.js"></script>
<script>
 const brand = <%- JSON.stringify(typeof brand !== "undefined" ? brand : null) %>;
  if(brand){
    const checkbox = document.querySelector('#'+brand);
    checkbox.checked = true;
  }
  </script>